# Copy to .env.local and fill in from https://dashboard.convex.dev
#
# IMPORTANT: dev and prod are different deployments. If you seed songs on prod
# but .env.local points at dev, the site will look empty or auth will fail.

# Production (Vercel + local testing against live data)
CONVEX_DEPLOYMENT=prod:peaceful-platypus-862
NEXT_PUBLIC_CONVEX_URL=https://peaceful-platypus-862.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://peaceful-platypus-862.convex.site

# Development (only when running `npx convex dev` — uncomment and comment prod above)
# CONVEX_DEPLOYMENT=dev:kindhearted-yak-653
# NEXT_PUBLIC_CONVEX_URL=https://kindhearted-yak-653.convex.cloud
# NEXT_PUBLIC_CONVEX_SITE_URL=https://kindhearted-yak-653.convex.site
